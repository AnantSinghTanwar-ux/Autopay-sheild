MONGODB_URI=mongodb://localhost:27017/autopay-shield
JWT_SECRET=your_super_secret_jwt_key_here
OPENWEATHER_API_KEY=your_openweather_api_key
WEATHER_API_KEY=your_openweather_api_key_legacy_optional
